{
  "manifest_version": 3,
  "name": "Answ",
  "version": "0.8.0",
  "description": "Answ — AI answer solver. Seleksi soal, dapatkan jawaban instan dari AI.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_title": "Answ — Atur API Key & Mulai Seleksi",
    "default_popup": "popup.html"
  }
}
